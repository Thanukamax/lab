---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Box from '../../components/Box.astro';
import { withBase, fmtDate } from '../../utils/url';

export async function getStaticPaths() {
  const posts = await getCollection('writing', (p) => !p.data.draft);
  return posts.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const d = post.data;

const others = (await getCollection('writing', (p) => !p.data.draft))
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const toc = headings.filter((h) => h.depth === 2);
---

<BaseLayout title={`${d.title} — Thanuka Perera`} description={d.description}>
  <div class="lq-article-cols">
    <div class="lq-article-main">
      <Box title={`${post.slug}.md`}>
        <p class="lq-crumb"><a href={withBase('writing')}>blog</a><span class="sep">/</span>{d.topic}</p>

        <div class="lq-article-head">
          <span class="lq-eyebrow">Field note · {d.topic}</span>
          <h1 class="lq-article-title">{d.title}</h1>
          <p class="lq-dek">{d.description}</p>
          <p class="lq-byline"><b>Thanuka Perera</b> · {fmtDate(d.date, true)} · {d.readTime} read</p>
        </div>

        <div class="lq-prose lq-prose--lead"><Content /></div>
      </Box>
    </div>

    <div class="lq-article-rail">
      {toc.length > 1 && (
        <Box title="on_this_page">
          <div class="lq-toc" style="padding:0"><ol>{toc.map((h) => <li><a href={`#${h.slug}`}>{h.text}</a></li>)}</ol></div>
        </Box>
      )}

      {others.length > 0 && (
        <Box title="read_next/" bodyStyle="padding:2px 11px">
          <div class="lq-posts">
            {others.map((p) => (
              <a class="lq-postrow" href={withBase(`writing/${p.slug}`)}>
                <span class="lq-postrow-topic">{p.data.topic}</span>
                <h3 class="lq-postrow-h">{p.data.title}</h3>
                <span class="lq-postrow-meta">{fmtDate(p.data.date)}<span class="read">{p.data.readTime}</span></span>
              </a>
            ))}
          </div>
        </Box>
      )}
    </div>
  </div>
</BaseLayout>
