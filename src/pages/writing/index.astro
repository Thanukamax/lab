---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Box from '../../components/Box.astro';
import Aside from '../../components/Aside.astro';
import { withBase, fmtDate } from '../../utils/url';

const posts = (await getCollection('writing', (p) => !p.data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Writing — Thanuka Perera" description="Build logs, field notes, and the occasional idea measured until it fell apart.">
  <div class="lq-scene-grid">
    <div class="lq-main">
      <Box title="blog/" id="blog">
        <p class="lq-box-title">field notes from the deep end</p>
        <p class="lq-bio">build logs, opinions, and the occasional idea i measured until it fell apart — written from doing the thing, not reading about it. <a href={withBase('feed.xml')} style="color:var(--aqua)">subscribe via rss →</a></p>
        <div class="lq-rule"></div>
      </Box>

      <Box title="all_entries.idx" bodyStyle="padding:2px 13px">
        <div class="lq-posts">
          {posts.map((post) => (
            <a class="lq-postrow" href={withBase(`writing/${post.slug}`)}>
              <span class="lq-postrow-topic">{post.data.topic}</span>
              <h3 class="lq-postrow-h">{post.data.title}</h3>
              <p class="lq-postrow-desc">{post.data.description}</p>
              <span class="lq-postrow-meta">{fmtDate(post.data.date)}<span class="read">{post.data.readTime}</span></span>
            </a>
          ))}
        </div>
      </Box>
    </div>

    <Aside />
  </div>
</BaseLayout>
