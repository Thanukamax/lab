---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getThumb } from '../utils/thumbs';
import { getHero } from '../utils/heroes';
import { withBase, fmtDate } from '../utils/url';
import { verdict } from '../utils/verdict';

const projects = (await getCollection('projects', (p) => !p.data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
const featured = projects.filter((p) => p.data.featured).slice(0, 3);

const posts = (await getCollection('writing', (p) => !p.data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const lead = posts[0];
const rest = posts.slice(1, 4);
const arrow = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
---

<BaseLayout>
  <Nav />
  <main id="top" class="lq-content">
    <header class="lq-intro">
      <p class="lq-eyebrow">thanuka.lab · field notes</p>
      <h1>I build systems, then measure them until they tell me the <em>truth</em>.</h1>
      <p class="lq-intro-bio">
        Backends, systems tools, and AI that runs on your own machine — then write up what broke
        and what held. Sometimes the idea works; sometimes I measure it, it falls apart, and that
        one gets written up too. The negative results count.
      </p>
      <p class="lq-intro-meta">
        <b>{posts.length}</b> field notes&nbsp;&nbsp;·&nbsp;&nbsp;<b>{projects.length}</b> projects
        &nbsp;&nbsp;·&nbsp;&nbsp;<a href="https://github.com/Thanukamax">github</a>
        &nbsp;&nbsp;·&nbsp;&nbsp;<a href={withBase('feed.xml')}>rss</a>
      </p>
    </header>

    {lead && (
      <section class="lq-section lq-wide">
        <div class="lq-sechead"><h2><span class="lq-drop"></span>Latest</h2><a href={withBase('writing')}>All writing</a></div>
        <a class="lq-glass lq-glass--interactive lq-feature" href={withBase(`writing/${lead.slug}`)}>
          <div class="lq-feature-art"><span class="lq-verdict lq-verdict--shipped"><span class="g">●</span>New</span></div>
          <div class="lq-feature-body">
            <span class="lq-feature-topic">{lead.data.topic} · {fmtDate(lead.data.date)}</span>
            <h3>{lead.data.title}</h3>
            <p class="lq-feature-dek">{lead.data.description}</p>
            <div class="lq-feature-meta"><span>{lead.data.readTime} read</span><span class="go">Read note <Fragment set:html={arrow} /></span></div>
          </div>
        </a>
      </section>
    )}

    {rest.length > 0 && (
      <section class="lq-section lq-wide">
        <div class="lq-sechead"><h2><span class="lq-drop"></span>Writing</h2><a href={withBase('writing')}>All notes →</a></div>
        <div class="lq-glass lq-posts" style="padding:4px 14px">
          {rest.map((post) => (
            <a class="lq-postrow" href={withBase(`writing/${post.slug}`)}>
              <span class="lq-postrow-topic">{post.data.topic}</span>
              <h3 class="lq-postrow-h">{post.data.title}</h3>
              <p class="lq-postrow-desc">{post.data.description}</p>
              <span class="lq-postrow-meta">{fmtDate(post.data.date)}<span class="read">{post.data.readTime}</span></span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="lq-section lq-wide">
      <div class="lq-sechead"><h2><span class="lq-drop"></span>Selected work</h2><a href={withBase('projects')}>All {projects.length} →</a></div>
      <div class="lq-grid" style="grid-template-columns:repeat(auto-fill,minmax(260px,1fr))">
        {featured.map((p) => { const v = verdict(p.data.status); return (
          <a class="lq-glass lq-glass--interactive lq-card" href={withBase(`projects/${p.slug}`)}>
            <div class="lq-card-art">
              {p.data.heroImage ? <img src={p.data.heroImage} alt="" /> : <Fragment set:html={getHero(p.slug) ?? getThumb(p.data.topic)} />}
              <span class={`lq-verdict lq-verdict--${v.kit}`}><span class="g">{v.glyph}</span>{v.label}</span>
            </div>
            <div class="lq-card-body">
              <span class="lq-card-topic">{p.data.topic}</span>
              <h3 class="lq-card-title">{p.data.title}</h3>
              <p class="lq-card-summary">{p.data.summary}</p>
              <div class="lq-stack">{p.data.stack.slice(0, 3).map((s) => <span class="lq-chip">{s}</span>)}</div>
            </div>
          </a>
        ); })}
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
