---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About — Thanuka Perera" description="Computer Science undergraduate and open-source builder from Colombo, Sri Lanka.">
  <Nav />
  <main id="top" class="lq-content">
    <article class="lq-section lq-doc-section">
      <div class="lq-article-head">
        <span class="lq-eyebrow">thanuka.lab · about</span>
        <h1 class="lq-article-title">Thanuka Perera</h1>
        <p class="lq-dek">Computer Science undergraduate and open-source builder from Colombo, Sri Lanka.</p>
      </div>

      <div class="lq-doc">
        <div class="lq-doc-main">
          <div class="lq-glass" style="padding:clamp(24px,4vw,40px)">
            <div class="lq-prose lq-prose--lead">
              <p>
                I'm a second-year CS student at the University of Westminster (via IIT, Colombo), but most
                of what I actually know I learned by building things, shipping them, and watching a fair
                few of them fall apart the moment I measured them. I work across the stack — cloud-native
                backends, systems-level tooling in Rust and C++, and AI that runs entirely on-device —
                usually on a laptop with a 4&nbsp;GB GPU that keeps me honest about performance.
              </p>
              <h2>What I care about</h2>
              <p>
                The low-level details other people skip: binary formats, cache behaviour, where a frame
                actually went. The difference between a tool that works and one that feels instant. I
                treat <strong>latency as a feature</strong>, I write tests for things I could get away
                with not testing, and I'd rather publish an honest negative result — "turns out this
                doesn't work, here's why" — than a hyped claim that doesn't survive a bigger sample size.
                Measure before you build. Not as a virtue; as self-defense.
              </p>
              <h2>Right now</h2>
              <p>
                Building <strong>shrinkray</strong> (reversible texture compression for game installs),
                <strong> Diana</strong> (a local-first voice assistant), and contributing to open-source
                projects — currently somewhere between "this is brilliant" and "why did I think this would
                work." Long-term, I want to work on the kind of enterprise platforms and developer
                infrastructure that real systems are built on.
              </p>
            </div>
          </div>
        </div>

        <aside class="lq-doc-aside">
          <p class="lq-aside-title">Profile</p>
          <div class="lq-glass lq-specs" style="padding:18px 22px">
            <div><span class="k">Role</span><span class="v">CS undergrad · open-source builder</span></div>
            <div><span class="k">Based in</span><span class="v">Colombo, Sri Lanka</span></div>
            <div><span class="k">Focus</span><span class="v">Backends · systems · on-device AI</span></div>
            <div><span class="k">Building</span><span class="v">shrinkray · Diana</span></div>
          </div>

          <p class="lq-aside-title">Get in touch</p>
          <div class="lq-detaillinks">
            <a class="lq-gel lq-gel--primary" href="mailto:thanukasehasnaperera@gmail.com">Email ↗</a>
            <a class="lq-gel lq-gel--ghost" href="https://github.com/Thanukamax">GitHub ↗</a>
            <a class="lq-gel lq-gel--ghost" href="https://thanukamax.github.io">Portfolio ↗</a>
            <a class="lq-gel lq-gel--ghost" href="https://www.linkedin.com/in/thanuka-perera-889240337">LinkedIn ↗</a>
          </div>
        </aside>
      </div>
    </article>

    <Footer />
  </main>
</BaseLayout>
