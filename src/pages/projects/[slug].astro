---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Box from '../../components/Box.astro';
import { getThumb } from '../../utils/thumbs';
import { getHero } from '../../utils/heroes';
import { withBase } from '../../utils/url';
import { verdict } from '../../utils/verdict';

export async function getStaticPaths() {
  const projects = await getCollection('projects', (p) => !p.data.draft);
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const d = project.data;
const v = verdict(d.status);

const others = (await getCollection('projects', (p) => !p.data.draft))
  .filter((p) => p.slug !== project.slug)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const linkLabels: Record<string, string> = { repo: 'Source', demo: 'Demo', pypi: 'PyPI', site: 'Live site' };
const links = Object.entries(d.links).filter(([, val]) => val) as [string, string][];
---

<BaseLayout title={`${d.title} — Thanuka Perera`} description={d.summary}>
  <div class="lq-article-cols">
    <div class="lq-article-main">
      <Box title={`${project.slug}.proj`}>
        <p class="lq-crumb"><a href={withBase('projects')}>projects</a><span class="sep">/</span>{d.topic}</p>

        <div class="lq-article-head">
          <span class="lq-eyebrow">{d.topic} · {d.year}</span>
          <h1 class="lq-article-title">{d.title}</h1>
          <p class="lq-dek">{d.summary}</p>
          <p style="margin-top:12px"><span class={`lq-verdict lq-verdict--${v.kit}`}><span class="g">{v.glyph}</span>{v.label}</span></p>
        </div>

        <figure class="lq-detail-art" style="margin:16px 0">
          {d.heroImage ? <img src={d.heroImage} alt="" /> : <Fragment set:html={getHero(project.slug) ?? getThumb(d.topic)} />}
        </figure>

        <div class="lq-prose"><Content /></div>
      </Box>
    </div>

    <div class="lq-article-rail">
      <Box title="details.ini">
        <div class="lq-statline"><span>role</span><b>{d.role}</b></div>
        <div class="lq-statline"><span>year</span><b>{d.year}</b></div>
        <div class="lq-statline"><span>stack</span><b style="text-align:right">{d.stack.join(' · ')}</b></div>
        {links.length > 0 && (
          <div class="lq-stack" style="margin-top:12px">
            {links.map(([k, val], i) => (
              <a class={`lq-gel ${i === 0 ? 'lq-gel--primary' : 'lq-gel--ghost'}`} href={val}>{linkLabels[k] ?? k} ↗</a>
            ))}
          </div>
        )}
      </Box>

      {others.length > 0 && (
        <Box title="more_work/" bodyStyle="padding:2px 11px">
          <div class="lq-posts">
            {others.map((p) => { const ov = verdict(p.data.status); return (
              <a class="lq-postrow" href={withBase(`projects/${p.slug}`)}>
                <span class="lq-postrow-topic">{p.data.topic}</span>
                <h3 class="lq-postrow-h">{p.data.title}</h3>
                <span class="lq-postrow-meta">{p.data.year}<span class="read">{ov.label}</span></span>
              </a>
            ); })}
          </div>
        </Box>
      )}
    </div>
  </div>
</BaseLayout>
