---
import '../liquid-kit/liquid.css';
import '../styles/site.css';
import { withBase } from '../utils/url';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Thanuka Perera — Lab',
  description = 'Projects and field notes on backend, systems, and on-device AI — rendered on a little water.',
} = Astro.props;
const feed = withBase('feed.xml');
const favicon = withBase('favicon.svg');
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Thanuka Perera — Writing" href={feed} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // set theme + ui-mode before paint to avoid a flash
      (() => {
        try {
          const r = document.documentElement;
          r.setAttribute('data-theme', localStorage.getItem('liquid-theme') || 'dark');
          if ((localStorage.getItem('liquid-ui') || 'glass') === 'android') r.classList.add('ui-android');
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="lq-root">
    <canvas id="bg" class="lq-bg"></canvas>
    <div id="staticBg" class="lq-bg-static" aria-hidden="true"></div>
    <div class="lq-scrim" aria-hidden="true"></div>

    <slot />

    <button class="lq-fab" id="fab" type="button" aria-label="Back to top">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>

    <script>
      import { LiquidFluid } from '../liquid-kit/fluid.js';

      const root = document.documentElement;
      const canvas = document.getElementById('bg');
      const staticBg = document.getElementById('staticBg');

      const SUN = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>';
      const MOON = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>';

      let theme = (() => { try { return localStorage.getItem('liquid-theme') || 'dark'; } catch (_) { return 'dark'; } })();
      const fluid = new LiquidFluid(canvas, { theme });
      if (!fluid.ok) staticBg.classList.add('is-on'); // reduced-motion / no WebGL → static ocean

      // ---- theme toggle ----
      const themeBtn = document.getElementById('themeToggle');
      function applyTheme(t) {
        theme = t; root.setAttribute('data-theme', t);
        if (themeBtn) themeBtn.innerHTML = t === 'dark' ? MOON : SUN;
        if (fluid) fluid.setTheme(t);
        try { localStorage.setItem('liquid-theme', t); } catch (_) {}
      }
      themeBtn?.addEventListener('click', () => applyTheme(theme === 'dark' ? 'light' : 'dark'));
      applyTheme(theme);

      // ---- UI mode: Glass (iOS-like) / Material (Android) ----
      const uiSeg = document.getElementById('uiSeg');
      let uiMode = (() => { try { return localStorage.getItem('liquid-ui') || 'glass'; } catch (_) { return 'glass'; } })();
      function applyUI(m) {
        uiMode = m; root.classList.toggle('ui-android', m === 'android');
        uiSeg?.querySelectorAll('button').forEach((b) => b.setAttribute('aria-pressed', b.dataset.ui === m ? 'true' : 'false'));
        try { localStorage.setItem('liquid-ui', m); } catch (_) {}
      }
      uiSeg?.addEventListener('click', (e) => { const b = e.target.closest('button'); if (b) applyUI(b.dataset.ui); });
      applyUI(uiMode);

      // ---- water-drop sound (synth, opt-in) ----
      let actx = null, soundOn = (() => { try { return localStorage.getItem('liquid-sound') === 'on'; } catch (_) { return false; } })();
      const soundBtn = document.getElementById('soundToggle');
      const paintSound = () => soundBtn?.classList.toggle('off', !soundOn);
      paintSound();
      const ensureCtx = () => { if (!actx) { const AC = window.AudioContext || window.webkitAudioContext; if (AC) actx = new AC(); } if (actx?.state === 'suspended') actx.resume(); return actx; };
      function drop() {
        if (!soundOn) return; const c = ensureCtx(); if (!c) return;
        const t = c.currentTime, o = c.createOscillator(), g = c.createGain();
        o.type = 'sine';
        o.frequency.setValueAtTime(880, t);
        o.frequency.exponentialRampToValueAtTime(210, t + 0.13);
        g.gain.setValueAtTime(0.0001, t);
        g.gain.exponentialRampToValueAtTime(0.3, t + 0.012);
        g.gain.exponentialRampToValueAtTime(0.0001, t + 0.32);
        o.connect(g).connect(c.destination); o.start(t); o.stop(t + 0.34);
      }
      soundBtn?.addEventListener('click', () => {
        soundOn = !soundOn; paintSound();
        try { localStorage.setItem('liquid-sound', soundOn ? 'on' : 'off'); } catch (_) {}
        if (soundOn) { ensureCtx(); drop(); }
      });

      // ---- Mic: blow / talk into the mic and the water gusts (engine.blow) ----
      const micBtn = document.getElementById('micToggle');
      let micOn = false, micStream = null, micRAF = 0;
      const paintMic = () => micBtn?.classList.toggle('off', !micOn);
      async function startMic() {
        const c = ensureCtx(); if (!c) return;
        try {
          micStream = await navigator.mediaDevices.getUserMedia({ audio: { echoCancellation: false, noiseSuppression: false } });
          const src = c.createMediaStreamSource(micStream);
          const an = c.createAnalyser(); an.fftSize = 512; src.connect(an);
          const data = new Uint8Array(an.fftSize);
          const loop = () => {
            an.getByteTimeDomainData(data);
            let sum = 0; for (let i = 0; i < data.length; i++) { const v = (data[i] - 128) / 128; sum += v * v; }
            const rms = Math.sqrt(sum / data.length);          // 0..~1
            const level = Math.min(2, rms * 7);                // scale into blow() range
            if (fluid.ok && level > 0.08) fluid.blow(level);   // ignore room noise floor
            micRAF = requestAnimationFrame(loop);
          };
          loop(); micOn = true; paintMic();
        } catch (_) { micOn = false; paintMic(); }             // denied / unavailable → stay off
      }
      function stopMic() {
        if (micRAF) cancelAnimationFrame(micRAF); micRAF = 0;
        micStream?.getTracks().forEach((t) => t.stop()); micStream = null;
        micOn = false; paintMic();
      }
      micBtn?.addEventListener('click', () => { micOn ? stopMic() : startMic(); });
      window.addEventListener('pagehide', stopMic);

      // ---- RippleFX: a tap drops into the fluid (+ water ring + sound) ----
      window.addEventListener('pointerdown', (e) => {
        if (e.pointerType === 'mouse' && e.button !== 0) return;
        const r = document.createElement('div');
        r.className = 'lq-ripple'; r.style.left = e.clientX + 'px'; r.style.top = e.clientY + 'px';
        document.body.appendChild(r); setTimeout(() => r.remove(), 660);
        if (fluid.ok) fluid.splatAt(e.clientX, e.clientY);
        addMaterialRipple(e);
        drop();
      }, { passive: true });

      // ---- Material touch ripple (android mode only) ----
      function addMaterialRipple(e) {
        if (!root.classList.contains('ui-android')) return;
        const el = e.target.closest('.lq-gel, .lq-iconbtn, .lq-fab, .lq-pill, .lq-work, .lq-card, .lq-postrow');
        if (!el) return;
        el.classList.add('md-ripple-host');
        const rect = el.getBoundingClientRect(), d = Math.max(rect.width, rect.height);
        const s = document.createElement('span'); s.className = 'md-ripple';
        s.style.width = s.style.height = d + 'px';
        s.style.left = (e.clientX - rect.left - d / 2) + 'px';
        s.style.top = (e.clientY - rect.top - d / 2) + 'px';
        el.appendChild(s); setTimeout(() => s.remove(), 560);
      }

      // ---- FAB: back to top + a little splash ----
      document.getElementById('fab')?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        if (fluid.ok) fluid.multipleSplats(5);
      });
    </script>
  </body>
</html>
