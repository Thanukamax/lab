---
import '../liquid-kit/liquid.css';
import '../styles/site.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/url';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Thanuka Perera — Lab',
  description = 'Projects and field notes on backend, systems, and on-device AI — rendered on a little water.',
} = Astro.props;
const feed = withBase('feed.xml');
const favicon = withBase('favicon.svg');
const banner = withBase('hero-banner.png');
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Thanuka Perera — Writing" href={feed} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Silkscreen:wght@400;700&family=VT323&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // set theme before paint to avoid a flash (Steel is the only skin)
      (() => {
        try {
          const r = document.documentElement;
          r.setAttribute('data-theme', localStorage.getItem('liquid-theme') || 'dark');
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="lq-root">
    <canvas id="bg" class="lq-bg"></canvas>
    <div id="staticBg" class="lq-bg-static" aria-hidden="true"></div>
    <div class="lq-scrim" aria-hidden="true"></div>
    <div class="lq-grain" aria-hidden="true"></div>

    <div class="lq-scene" id="top">
      <div class="lq-banner-wrap"><img src={banner} alt="thanuka.lab — a personal site on water" /></div>

      <Nav />

      <div class="lq-glass lq-marquee" aria-label="site ticker">
        <span><span class="star">★</span> welcome to thanuka.lab — you are visitor no. <b id="mq-hits">…</b> &nbsp;·&nbsp; now building <i>warmcore</i> &nbsp;·&nbsp; the water remembers your cursor &nbsp;·&nbsp; measure before you build &nbsp;·&nbsp; the negative results count &nbsp;·&nbsp; best viewed with a pulse &nbsp;·&nbsp; <b>MAKE UI GREAT AGAIN</b> &nbsp;<span class="star">★</span></span>
      </div>

      <slot />

      <Footer />
    </div>

    <button class="lq-fab" id="fab" type="button" aria-label="Back to top">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>

    <script>
      import { LiquidFluid } from '../liquid-kit/fluid.js';
      import { initConscious } from '../liquid-kit/conscious.js';

      const root = document.documentElement;
      const canvas = document.getElementById('bg');
      const staticBg = document.getElementById('staticBg');

      const SUN = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>';
      const MOON = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>';

      let theme = (() => { try { return localStorage.getItem('liquid-theme') || 'dark'; } catch (_) { return 'dark'; } })();
      const fluid = new LiquidFluid(canvas, { theme });
      if (!fluid.ok) staticBg.classList.add('is-on'); // reduced-motion / no WebGL → static ocean

      // ---- theme toggle ----
      const themeBtn = document.getElementById('themeToggle');
      function applyTheme(t) {
        theme = t; root.setAttribute('data-theme', t);
        if (themeBtn) themeBtn.innerHTML = t === 'dark' ? MOON : SUN;
        if (fluid) fluid.setTheme(t);
        try { localStorage.setItem('liquid-theme', t); } catch (_) {}
      }
      themeBtn?.addEventListener('click', () => applyTheme(theme === 'dark' ? 'light' : 'dark'));
      applyTheme(theme);

      // ---- Steel is the only skin: never engage the Material/Android texture ----
      root.classList.remove('ui-android');
      try { localStorage.removeItem('liquid-ui'); } catch (_) {}

      // ---- RippleFX: a tap drops into the fluid ----
      window.addEventListener('pointerdown', (e) => {
        if (e.pointerType === 'mouse' && e.button !== 0) return;
        if (e.target.closest('.lq-box-bar .x')) return; // close button handles its own feedback
        const r = document.createElement('div');
        r.className = 'lq-ripple'; r.style.left = e.clientX + 'px'; r.style.top = e.clientY + 'px';
        document.body.appendChild(r); setTimeout(() => r.remove(), 660);
        if (fluid.ok) fluid.splatAt(e.clientX, e.clientY);
      }, { passive: true });

      // ---- window chrome: the × closes its box (early-web window, restored on reload) ----
      document.querySelectorAll('.lq-box-bar .x').forEach((x) => {
        x.setAttribute('role', 'button');
        x.setAttribute('aria-label', 'close window');
        x.addEventListener('click', (e) => {
          e.preventDefault(); e.stopPropagation();
          const box = x.closest('.lq-box');
          if (!box) return;
          box.style.transition = 'opacity .18s ease, transform .18s ease';
          box.style.opacity = '0'; box.style.transform = 'scale(.985)';
          setTimeout(() => { box.classList.add('is-closed'); box.style.cssText = ''; }, 180);
        });
      });

      // ---- TOC scroll-spy: highlight the section currently in view ----
      const tocLinks = [...document.querySelectorAll('.lq-toc a[href^="#"]')];
      if (tocLinks.length) {
        const byId = new Map(tocLinks.map((a) => [decodeURIComponent(a.getAttribute('href').slice(1)), a]));
        const heads = [...document.querySelectorAll('.lq-prose h2[id]')].filter((h) => byId.has(h.id));
        const spy = new IntersectionObserver((entries) => {
          entries.forEach((en) => {
            if (!en.isIntersecting) return;
            tocLinks.forEach((a) => a.classList.remove('is-active'));
            byId.get(en.target.id)?.classList.add('is-active');
          });
        }, { rootMargin: '-12% 0px -78% 0px' });
        heads.forEach((h) => spy.observe(h));
      }

      // ---- FAB: back to top + a little splash ----
      document.getElementById('fab')?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        if (fluid.ok) fluid.multipleSplats(5);
      });

      // ---- ⚡ make the site conscious (hit counter, uptime, commit log, status) ----
      initConscious({ launch: '2003-08-01T00:00:00' });
      setTimeout(() => {
        const h = document.querySelector('[data-cx="hits"]');
        const mq = document.getElementById('mq-hits');
        if (h && mq) mq.textContent = (h.textContent || '').replace(/^0+/, '') || h.textContent;
      }, 60);
    </script>
  </body>
</html>
