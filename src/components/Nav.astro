---
import { withBase } from '../utils/url';
const path = Astro.url.pathname.replace(/\/$/, '');
const isActive = (p: string) => {
  const target = withBase(p).replace(/\/$/, '');
  return p === '' ? path === target : path.startsWith(target);
};
---

<nav class="lq-glass lq-navbar">
  <a href={withBase('')} aria-current={isActive('') ? 'page' : undefined}>home</a>
  <a href={withBase('about')} aria-current={isActive('about') ? 'page' : undefined}>about.me</a>
  <a href={withBase('writing')} aria-current={isActive('writing') ? 'page' : undefined}>blog</a>
  <a href={withBase('projects')} aria-current={isActive('projects') ? 'page' : undefined}>projects</a>
  <a href={withBase('feed.xml')}>rss</a>
  <span class="lq-navtools">
    <button id="themeToggle" class="lq-iconbtn" type="button" aria-label="Toggle dark / light"></button>
  </span>
</nav>
