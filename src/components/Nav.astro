---
import { withBase } from '../utils/url';
const path = Astro.url.pathname.replace(/\/$/, '');
const isActive = (p: string) => {
  const target = withBase(p).replace(/\/$/, '');
  return p === '' ? path === target : path.startsWith(target);
};
---

<nav class="nav">
  <div class="nav-inner">
    <a class="brand" href={withBase('')}>thanuka<span class="dot-accent">.</span>lab</a>
    <div class="nav-links">
      <a href={withBase('writing')} aria-current={isActive('writing') ? 'page' : undefined}>Writing</a>
      <a href={withBase('projects')} aria-current={isActive('projects') ? 'page' : undefined}>Projects</a>
      <a href={withBase('about')} aria-current={isActive('about') ? 'page' : undefined}>About</a>
      <a class="icon-btn" href={withBase('feed.xml')} aria-label="RSS feed" style="margin-left:6px">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 17.82A2.18 2.18 0 1 1 4 20a2.18 2.18 0 0 1 2.18-2.18zM4 11.03v3.01c3.6 0 6.53 2.93 6.53 6.53h3.01c0-5.27-4.27-9.54-9.54-9.54zm0-6.02V8c7.74 0 14 6.26 14 14h3c0-9.4-7.6-17-17-17z"/></svg>
      </a>
      <button class="icon-btn" id="theme-toggle" aria-label="Toggle colour theme">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4"/></svg>
      </button>
    </div>
  </div>
</nav>
